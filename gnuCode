import time
import numpy as np
import csv
import os #for creation time!!!!

# Done in HH:MM:SS
#Variables that can be changed
sample_rate = 250000
increment_of_data=.1


file_name="GnuTestFileNOAAFILEe.bin"
data = np.fromfile(file_name, dtype=np.complex64)
time_zone_diff_milli=21600000 #our time zone diff in milliseconds from UTC. DONT CHANGE.

#Gets the time of which the file was created
running_time_time=(os.path.getctime(file_name))

#Sets this variable for later usage lols >.<
time_local=""
#------------------
#High key need to determine the best way to actually determine where the noise floor is or not
#------------------
#6 smallest values
noise_floor_values=[0,0,0,0,0,0];

# Average into 0.5 second chunks

#INTO .1 CHUNCKS
chunk_size = int(sample_rate * increment_of_data)  #1,000,000 samples per 0.5 seconds


#Array that contain increments of data. 
#Like if you ask for a minute, a minute also is an array of seconds. But you can just refer to it as minute.
#The first array is minutes and the second array is the seconds
chunks = [data[i:i+chunk_size] for i in range(0, len(data), chunk_size)]
#Opening new file lols!
#

#I think I need to create a for loop or something so that itll run for a certain amount of time, but each file created 
#has a incremental value. Like have it close the file once some time threshold has been hit. Maybe like 1 day?
#then close this file, open another of the same format BUT with an f-string, so like itd be f'NOAADataFile{i}' or 
#something. Will do once I have access to the pie :P
newFileName='NOAAdatafile'
iterationNum=0;
#
with open(f'{newFileName}{iterationNum}.cvs', 'w', newline='') as f:
    minimum=sum(noise_floor_values)/len(noise_floor_values)#minumum value found
    current_i=0;
    gap=.01# reasonable gap
    #CSV DOC IS GREAT
    writer = csv.writer(f)
    writer.writerow(['Time (s)', 'Avg Power (dB)','Pwr Diff','TimeStamp??'])
    for i, chunk in enumerate(chunks):
        noise_floor_values.sort()
        
        timesince = i * 0.1
        running_time+=.1
        time_local=time.ctime(running_time)
        
        #Can do some string splicing here lols

        
        avg_power = 10 * np.log10(np.mean(np.abs(chunk)**2) + 1e-10)
        if avg_power<noise_floor_values[5]:
            #sort the changed array
            noise_floor_values.pop()
            noise_floor_values.append(avg_power)
            noise_floor_values.sort()
            minimum=sum(noise_floor_values)/len(noise_floor_values)
        if avg_power-gap>minimum:
            current_i=abs(minimum-avg_power)
        writer.writerow([timesince, avg_power,current_i,time_local])
        current_i=0;
        time_local=""
print(running_time)
print(f"Written {len(chunks)} rows to output.csv")



